{
  "name": "clinica-odontoface",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Gestão para Clínica Odontológica e Harmonização Orofacial",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @clinica/api exec prisma generate",
    "db:migrate": "pnpm --filter @clinica/api exec prisma migrate dev",
    "db:push": "pnpm --filter @clinica/api exec prisma db push",
    "db:seed": "pnpm --filter @clinica/api exec prisma db seed",
    "db:studio": "pnpm --filter @clinica/api exec prisma studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}

